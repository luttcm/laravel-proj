                "operationId": "c2cb61bc10191925f0914256f1ed8d1d",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "required": [
                                    "report_title",
                                    "deal_payment"
                                ],
                                "properties": {
                                    "report_title": {
                                        "type": "string"
                                    },
                                    "deal_payment": {
                                        "type": "number",
                                        "format": "float"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "302": {
                        "description": "Перенаправление"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/findirector/fin-reports/{id}": {
            "put": {
                "tags": [
                    "FinDirector"
                ],
                "summary": "Обновить финансовый отчет",
                "operationId": "f0e2a8cb9c67ec1c4bd7a79e133835d5",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "required": [
                                    "report_title",
                                    "deal_payment"
                                ],
                                "properties": {
                                    "report_title": {
                                        "type": "string"
                                    },
                                    "deal_payment": {
                                        "type": "number",
                                        "format": "float"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "302": {
                        "description": "Перенаправление"
                    },
                    "403": {
                        "description": "Доступ запрещен"
                    },
                    "404": {
                        "description": "Отчет не найден"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
